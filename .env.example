# Copy this file to .env for local development.
# Do not commit .env.

APP_ENV=development
LOG_LEVEL=INFO

AI_PROVIDER=router
AI_ROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_ROUTER_API_KEY=
AI_ROUTER_API_KEYS=
AI_ROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
AI_ROUTER_MODELS=google/gemma-3-12b-it:free,meta-llama/llama-3.3-8b-instruct:free,mistralai/mistral-7b-instruct:free
AI_ROUTER_TIMEOUT_SECONDS=30
AI_ROUTER_TEMPERATURE=0.2
AI_ROUTER_MAX_TOKENS=1200

GEMINI_API_KEY=
GEMINI_MODELS=gemini-1.5-flash,gemini-1.5-pro

AI_MAX_RETRY_LOOPS=2

ENABLE_AI_INSIGHTS=true
ENABLE_RAG_AI=true
