# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs and local runtime files
*.log
logs/*.jsonl
!logs/.gitkeep

# Data outputs
data/raw/*.json
data/processed/*.json
data/analytics/*.csv
data/analytics/*.json
data/trends/*.csv
data/trends/*.json
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample/.gitkeep
!data/analytics/.gitkeep
!data/trends/.gitkeep

# Reports generated by later modules
reports/*
!reports/.gitkeep

# Evaluation outputs generated by later modules
evals/*
!evals/.gitkeep
