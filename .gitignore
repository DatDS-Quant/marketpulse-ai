# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
pytest-cache-files-*/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Environment files
.env
.env.*
!.env.example

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Logs and local runtime files
*.log
logs/*.jsonl
!logs/.gitkeep

# Data outputs
data/raw/*.json
data/processed/*.json
data/analytics/*.csv
data/analytics/*.json
data/trends/*.csv
data/trends/*.json
data/insights/*.json
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/sample/.gitkeep
!data/analytics/.gitkeep
!data/trends/.gitkeep
!data/insights/.gitkeep
data/evidence/*.json
!data/evidence/.gitkeep
data/rag/*.json
!data/rag/.gitkeep

# Reports generated by later modules
reports/generated/*.md
reports/generated/*.pdf
!reports/generated/.gitkeep
!reports/samples/*
!reports/templates/*

# Evaluation outputs generated by later modules
evals/*
!evals/.gitkeep

# Next.js Frontend
web/node_modules/
web/.next/
web/out/
web/.env.local
web/.env*.local
!web/.env.local.example